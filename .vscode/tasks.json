{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "extension: watch esbuild",
			"type": "npm",
			"script": "watch:esbuild",
			"path": "extension",
			"group": "build",
			// Defined inline rather than using `$esbuild-watch`, which is NOT built into
			// VS Code -- it ships with the connor4312.esbuild-problem-matchers extension.
			// The patterns match what esbuild.js prints via esbuildProblemMatcherPlugin.
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": ["relative", "${workspaceFolder}/extension"],
				"pattern": [
					{
						"regexp": "^✘ \\[ERROR\\] (.*)$",
						"message": 1
					},
					{
						"regexp": "^\\s+(.*):(\\d+):(\\d+):$",
						"file": 1,
						"line": 2,
						"column": 3
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started$",
					"endsPattern": "^\\[watch\\] build finished$"
				}
			},
			"isBackground": true,
			"presentation": { "group": "emberline", "reveal": "never" }
		},
		{
			"label": "extension: watch tsc",
			"type": "npm",
			"script": "watch:tsc",
			"path": "extension",
			"group": "build",
			// $tsc-watch IS built in (shipped by the TypeScript language features extension).
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": { "group": "emberline", "reveal": "never" }
		},
		{
			"label": "extension: watch",
			"dependsOn": ["extension: watch esbuild", "extension: watch tsc"],
			"dependsOrder": "parallel",
			"group": { "kind": "build", "isDefault": true },
			"problemMatcher": []
		},
		{
			"label": "server: start",
			"type": "shell",
			// Idempotent: if a server is already healthy, print the ready marker and
			// exit rather than failing on "address already in use".
			//
			// Otherwise wait for dist/server.js and run it. We wait rather than build:
			// this task runs in parallel with `extension: watch esbuild`, which is
			// already producing that file, and a second concurrent esbuild writing the
			// same outputs is a race worth not having.
			"command": "curl -sf -o /dev/null http://127.0.0.1:8011/health && echo 'Application startup complete (reusing already-running server)' || (until [ -f dist/server.js ]; do sleep 0.2; done && node dist/server.js)",
			"options": { "cwd": "${workspaceFolder}/extension" },
			"isBackground": true,
			"problemMatcher": {
				"owner": "emberline-server",
				"pattern": [
					{
						// \b\B can never match: this task reports readiness, not problems.
						"regexp": "\\b\\B",
						"file": 1,
						"location": 2,
						"message": 3
					}
				],
				"background": {
					"activeOnStart": true,
					// Both strings are printed by engine/main.ts. Change either there
					// and this task hangs on F5.
					"beginsPattern": "emberline server starting",
					"endsPattern": "Application startup complete"
				}
			},
			"presentation": { "group": "emberline", "panel": "dedicated" }
		},
		{
			"label": "dev: server + watch",
			"dependsOn": ["server: start", "extension: watch"],
			"dependsOrder": "parallel",
			"problemMatcher": []
		}
	]
}
